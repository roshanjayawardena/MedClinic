# Copy to .env and fill in values — never commit .env to git.

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# JWT — generate: openssl rand -base64 48
JWT_SECRET=change_me_must_be_at_least_32_chars_for_hmac_sha256

# MinIO / S3
MINIO_ACCESS_KEY=change_me_access_key
MINIO_SECRET_KEY=change_me_secret_key

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@mediclinic.app

# OpenTelemetry (optional)
OTLP_ENDPOINT=

# Docker image tag (set by CI/CD)
IMAGE_TAG=latest
GITHUB_REPOSITORY=your-org/mediclinic
